  "id": "1775256204935-63ddab9c",
  "siteId": "2e2106b9-3122-4d4f-a1ef-0244f16b5733",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>The Waypoint — Wakefield, RI</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <style>\n    .hero-bg { background-image: url('https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=1600&q=80'); background-size: cover; background-position: center; }\n    .card-hover { transition: transform 0.2s ease; }\n    .card-hover:hover { transform: translateY(-3px); }\n    .masonry-grid { columns: 2; column-gap: 1rem; }\n    @media (min-width: 768px) { .masonry-grid { columns: 3; } }\n    .masonry-grid img { break-inside: avoid; margin-bottom: 1rem; }\n  </style>\n</head>\n<body class=\"font-sans antialiased bg-yellow-50 text-stone-800\">\n\n  <!-- Nav -->\n  <nav class=\"sticky top-0 z-50 bg-yellow-50 border-b border-stone-200 shadow-sm\">\n    <div class=\"max-w-7xl mx-auto px-6 py-4 flex items-center justify-between\">\n      <div class=\"flex items-center gap-2\">\n        <span class=\"text-red-900 font-serif font-extrabold text-2xl tracking-tight\">The Waypoint</span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-8 text-sm font-medium\">\n        <a href=\"#menu\" class=\"text-stone-600 hover:text-red-900 transition-colors\">Menu</a>\n        <a href=\"#story\" class=\"text-stone-600 hover:text-red-900 transition-colors\">Our Story</a>\n        <a href=\"#reserve\" class=\"text-stone-600 hover:text-red-900 transition-colors\">Reserve</a>\n        <a href=\"#hours\" class=\"text-stone-600 hover:text-red-900 transition-colors\">Contact</a>\n      </div>\n      <a href=\"#reserve\" class=\"bg-red-900 hover:bg-red-800 text-yellow-50 px-5 py-2 rounded-lg font-semibold text-sm transition-colors\">Reserve a Table</a>\n    </div>\n  </nav>\n\n  <!-- Hero -->\n  <section class=\"hero-bg relative min-h-screen flex items-center justify-center\">\n    <div class=\"absolute inset-0 bg-black/60\"></div>\n    <div class=\"relative z-10 text-center px-6 max-w-3xl mx-auto\">\n      <span class=\"inline-block bg-amber-700/60 text-amber-200 text-xs font-semibold uppercase tracking-widest px-4 py-1 rounded-full mb-5\">Wakefield, Rhode Island</span>\n      <h1 class=\"text-6xl font-serif font-bold text-white leading-tight mb-5\">Where Craft<br /><span class=\"text-amber-400\">Meets Comfort.</span></h1>\n      <p class=\"text-gray-200 text-xl mb-8 leading-relaxed\">Locally sourced New England cuisine in the heart of South County. Farm-to-table ingredients, thoughtfully prepared. Open Tuesday through Sunday.</p>\n      <div class=\"flex flex-wrap justify-center gap-4\">\n        <a href=\"#reserve\" class=\"bg-red-800 hover:bg-red-700 text-white px-8 py-3 rounded-lg font-bold text-lg transition-colors\">Reserve a Table</a>\n        <a href=\"#menu\" class=\"border-2 border-white text-white hover:bg-white hover:text-red-900 px-8 py-3 rounded-lg font-bold text-lg transition-colors\">View Menu</a>\n      </div>\n    </div>\n  </section>\n\n  <!-- Menu -->\n  <section id=\"menu\" class=\"py-20 bg-stone-900 text-yellow-50\">\n    <div class=\"max-w-5xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-serif font-bold text-center mb-3\">Our Menu</h2>\n      <p class=\"text-stone-400 text-center mb-14\">Sourced from local farms and New England waters. Menu changes seasonally.</p>\n\n      <!-- Starters -->\n      <h3 class=\"text-2xl font-serif font-semibold text-amber-400 mb-6 border-b border-stone-700 pb-3\">Starters</h3>\n      <div class=\"grid md:grid-cols-2 gap-6 mb-12\">\n        <div class=\"flex justify-between gap-4\">\n          <div>\n            <div class=\"font-semibold text-yellow-50\">Narragansett Bay Oysters</div>\n            <div class=\"text-stone-400 text-sm mt-1\">Half dozen local oysters with house mignonette, cocktail sauce &amp; lemon</div>\n          </div>\n          <div class=\"text-amber-400 font-bold whitespace-nowrap\">$16</div>\n        </div>\n        <div class=\"flex justify-between gap-4\">\n          <div>\n            <div class=\"font-semibold text-yellow-50\">New England Clam Chowder</div>\n            <div class=\"text-stone-400 text-sm mt-1\">House-made creamy chowder with littleneck clams, applewood bacon &amp; chives</div>\n          </div>\n          <div class=\"text-amber-400 font-bold whitespace-nowrap\">$13</div>\n        </div>\n        <div class=\"flex justify-between gap-4\">\n          <div>\n            <div class=\"font-semibold text-yellow-50\">Burrata &amp; Heirloom Tomato</div>\n            <div class=\"text-stone-400 text-sm mt-1\">Local burrata, Shady Lea Farm tomatoes, basil oil, aged balsamic &amp; sea salt</div>\n          </div>\n          <div class=\"text-amber-400 font-bold whitespace-nowrap\">$15</div>\n        </div>\n        <div class=\"flex justify-between gap-4\">\n          <div>\n            <div class=\"font-semibold text-yellow-50\">Crispy Calamari</div>\n            <div class=\"text-stone-400 text-sm mt-1\">Lightly battered Rhode Island squid, banana peppers, house marinara &amp; aioli</div>\n          </div>\n          <div class=\"text-amber-400 font-bold whitespace-nowrap\">$14</div>\n        </div>\n      </div>\n\n      <!-- Mains -->\n      <h3 class=\"text-2xl font-serif font-semibold text-amber-400 mb-6 border-b border-stone-700 pb-3\">Mains</h3>\n      <div class=\"grid md:grid-cols-2 gap-6 mb-12\">\n        <div class=\"flex justify-between gap-4\">\n          <div>\n            <div class=\"font-semibold text-yellow-50\">Pan-Seared Striped Bass</div>\n            <div class=\"text-stone-400 text-sm mt-1\">RI-caught striped bass, roasted fingerling potatoes, grilled asparagus &amp; lemon beurre blanc</div>\n          </div>\n          <div class=\"text-amber-400 font-bold whitespace-nowrap\">$36</div>\n        </div>\n        <div class=\"flex justify-between gap-4\">\n          <div>\n            <div class=\"font-semibold text-yellow-50\">Wood-Grilled Ribeye</div>\n            <div class=\"text-stone-400 text-sm mt-1\">12oz Black Angus ribeye, truffle compound butter, crispy shallots &amp; roasted garlic mash</div>\n          </div>\n          <div class=\"text-amber-400 font-bold whitespace-nowrap\">$42</div>\n        </div>\n        <div class=\"flex justify-between gap-4\">\n          <div>\n            <div class=\"font-semibold text-yellow-50\">Free-Range Half Chicken</div>\n            <div class=\"text-stone-400 text-sm mt-1\">Johnston Farm chicken, herb jus, wilted greens, roasted root vegetables</div>\n          </div>\n          <div class=\"text-amber-400 font-bold whitespace-nowrap\">$28</div>\n        </div>\n        <div class=\"flex justify-between gap-4\">\n          <div>\n            <div class=\"font-semibold text-yellow-50\">Wild Mushroom Risotto</div>\n            <div class=\"text-stone-400 text-sm mt-1\">Arborio rice, mixed local mushrooms, parmesan reggiano, truffle oil &amp; micro herbs</div>\n          </div>\n          <div class=\"text-amber-400 font-bold whitespace-nowrap\">$26</div>\n        </div>\n      </div>\n\n      <!-- Desserts -->\n      <h3 class=\"text-2xl font-serif font-semibold text-amber-400 mb-6 border-b border-stone-700 pb-3\">Desserts</h3>\n      <div class=\"grid md:grid-cols-2 gap-6\">\n        <div class=\"flex justify-between gap-4\">\n          <div>\n            <div class=\"font-semibold text-yellow-50\">Warm Chocolate Lava Cake</div>\n            <div class=\"text-stone-400 text-sm mt-1\">Valrhona chocolate, vanilla bean ice cream, fresh berries</div>\n          </div>\n          <div class=\"text-amber-400 font-bold whitespace-nowrap\">$11</div>\n        </div>\n        <div class=\"flex justify-between gap-4\">\n          <div>\n            <div class=\"font-semibold text-yellow-50\">Crème Brûlée</div>\n            <div class=\"text-stone-400 text-sm mt-1\">Classic vanilla custard, torched sugar crust, seasonal fruit compote</div>\n          </div>\n          <div class=\"text-amber-400 font-bold whitespace-nowrap\">$10</div>\n        </div>\n        <div class=\"flex justify-between gap-4\">\n          <div>\n            <div class=\"font-semibold text-yellow-50\">Apple Tarte Tatin</div>\n            <div class=\"text-stone-400 text-sm mt-1\">Caramelized New England apples, puff pastry, house caramel, whipped cream</div>\n          </div>\n          <div class=\"text-amber-400 font-bold whitespace-nowrap\">$10</div>\n        </div>\n        <div class=\"flex justify-between gap-4\">\n          <div>\n            <div class=\"font-semibold text-yellow-50\">Local Ice Cream &amp; Sorbet</div>\n            <div class=\"text-stone-400 text-sm mt-1\">Three scoops from Gray's Ice Cream, Tiverton RI — seasonal flavors</div>\n          </div>\n          <div class=\"text-amber-400 font-bold whitespace-nowrap\">$9</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Hours & Location -->\n  <section id=\"hours\" class=\"py-20 bg-yellow-50\">\n    <div class=\"max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-start\">\n      <div>\n        <h2 class=\"text-3xl font-serif font-bold text-red-900 mb-6\">Hours &amp; Location</h2>\n        <div class=\"space-y-3 text-stone-700 mb-6\">\n          <div class=\"flex justify-between border-b border-stone-200 pb-2\"><span class=\"font-medium\">Monday</span><span class=\"text-stone-400\">Closed</span></div>\n          <div class=\"flex justify-between border-b border-stone-200 pb-2\"><span class=\"font-medium\">Tuesday – Thursday</span><span>5:00 pm – 9:00 pm</span></div>\n          <div class=\"flex justify-between border-b border-stone-200 pb-2\"><span class=\"font-medium\">Friday – Saturday</span><span>5:00 pm – 10:00 pm</span></div>\n          <div class=\"flex justify-between\"><span class=\"font-medium\">Sunday</span><span>11:00 am – 8:00 pm</span></div>\n        </div>\n        <div class=\"text-stone-700\">\n          <p class=\"font-bold text-red-900 text-lg\">The Waypoint</p>\n          <p>14 Main St, Wakefield RI 02879</p>\n          <p class=\"mt-1\"><a href=\"tel:4015550384\" class=\"text-red-800 font-semibold hover:underline\">(401) 555-0384</a></p>\n        </div>\n      </div>\n      <div>\n        <div class=\"w-full h-64 bg-stone-200 rounded-2xl flex flex-col items-center justify-center text-stone-500\">\n          <div class=\"text-4xl mb-3\">📍</div>\n          <p class=\"font-medium\">14 Main St, Wakefield RI 02879</p>\n          <a href=\"https://maps.google.com\" target=\"_blank\" class=\"mt-3 bg-red-900 text-white px-5 py-2 rounded-lg text-sm font-semibold hover:bg-red-800 transition-colors\">View on Google Maps</a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Photo Gallery -->\n  <section class=\"py-20 bg-stone-100\">\n    <div class=\"max-w-7xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-serif font-bold text-red-900 text-center mb-12\">A Taste of The Waypoint</h2>\n      <div class=\"masonry-grid\">\n        <img src=\"https://images.unsplash.com/photo-1540189549336-e6e99c3679fe?w=400&q=80\" alt=\"Dish\" class=\"rounded-xl w-full object-cover\" />\n        <img src=\"https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=400&q=80\" alt=\"Dish\" class=\"rounded-xl w-full object-cover\" />\n        <img src=\"https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?w=400&q=80\" alt=\"Dish\" class=\"rounded-xl w-full object-cover\" />\n        <img src=\"https://images.unsplash.com/photo-1565958011703-44f9829ba187?w=400&q=80\" alt=\"Dish\" class=\"rounded-xl w-full object-cover\" />\n        <img src=\"https://images.unsplash.com/photo-1484723091739-30a097e8f929?w=400&q=80\" alt=\"Dish\" class=\"rounded-xl w-full object-cover\" />\n        <img src=\"https://images.unsplash.com/photo-1567620905732-2d1ec7ab7445?w=400&q=80\" alt=\"Dish\" class=\"rounded-xl w-full object-cover\" />\n      </div>\n    </div>\n  </section>\n\n  <!-- Chef Story -->\n  <section id=\"story\" class=\"py-20 bg-yellow-50\">\n    <div class=\"max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center\">\n      <div>\n        <img src=\"https://images.unsplash.com/photo-1577219491135-ce391730fb2c?w=400&q=80\" alt=\"Chef Marcus\" class=\"rounded-2xl w-full object-cover shadow-lg\" />\n      </div>\n      <div>\n        <span class=\"text-amber-600 font-semibold text-sm uppercase tracking-widest\">Meet the Chef</span>\n        <h2 class=\"text-4xl font-serif font-bold text-red-900 mt-2 mb-5\">Chef Marcus Deluca</h2>\n        <p class=\"text-stone-600 leading-relaxed mb-4\">Chef Marcus grew up just down the road in Peace Dale before heading north to earn his culinary degree at the Cambridge School of Culinary Arts. He spent twelve years honing his craft in Boston's restaurant scene — including seven years as sous chef at the nationally recognized Harborview — before returning to South County to open The Waypoint in 2018.</p>\n        <p class=\"text-stone-600 leading-relaxed\">His approach is simple: use what's local, trust the seasons, and don't get in the way of great ingredients. Every menu changes monthly to reflect what's fresh from Johnston Farm in Hope Valley, Shady Lea Farm in North Kingstown, and the day boats out of Point Judith. \"South County raised me,\" he says. \"This restaurant is my way of giving it back.\"</p>\n      </div>\n    </div>\n  </section>\n\n  <!-- Reservations -->\n  <section id=\"reserve\" class=\"py-20 bg-red-900 text-yellow-50\">\n    <div class=\"max-w-2xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-serif font-bold text-center mb-3\">Reserve a Table</h2>\n      <p class=\"text-center text-red-200 mb-8\">Reservations are strongly recommended on weekends. Walk-ins welcome when available.</p>\n      <form class=\"bg-stone-900 rounded-2xl p-8 space-y-5\">\n        <div class=\"grid md:grid-cols-2 gap-5\">\n          <div>\n            <label class=\"block text-sm font-medium text-stone-300 mb-1\">Date</label>\n            <input type=\"date\" class=\"w-full border border-stone-600 bg-stone-800 text-white rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500\" />\n          </div>\n          <div>\n            <label class=\"block text-sm font-medium text-stone-300 mb-1\">Time</label>\n            <select class=\"w-full border border-stone-600 bg-stone-800 text-white rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500\">\n              <option>5:00 PM</option>\n              <option>5:30 PM</option>\n              <option>6:00 PM</option>\n              <option>6:30 PM</option>\n              <option>7:00 PM</option>\n              <option>7:30 PM</option>\n              <option>8:00 PM</option>\n              <option>8:30 PM</option>\n            </select>\n          </div>\n        </div>\n        <div>\n          <label class=\"block text-sm font-medium text-stone-300 mb-1\">Party Size</label>\n          <select class=\"w-full border border-stone-600 bg-stone-800 text-white rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500\">\n            <option>1 guest</option>\n            <option>2 guests</option>\n            <option>3 guests</option>\n            <option>4 guests</option>\n            <option>5 guests</option>\n            <option>6 guests</option>\n            <option>7+ guests — please call</option>\n          </select>\n        </div>\n        <div class=\"grid md:grid-cols-2 gap-5\">\n          <div>\n            <label class=\"block text-sm font-medium text-stone-300 mb-1\">Name</label>\n            <input type=\"text\" placeholder=\"Full name\" class=\"w-full border border-stone-600 bg-stone-800 text-white rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500\" />\n          </div>\n          <div>\n            <label class=\"block text-sm font-medium text-stone-300 mb-1\">Phone</label>\n            <input type=\"tel\" placeholder=\"(401) 555-0000\" class=\"w-full border border-stone-600 bg-stone-800 text-white rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500\" />\n          </div>\n        </div>\n        <button type=\"submit\" class=\"w-full bg-amber-600 hover:bg-amber-500 text-white py-3 rounded-lg font-bold transition-colors\">Confirm Reservation</button>\n      </form>\n    </div>\n  </section>\n\n  <!-- Footer -->\n  <footer class=\"bg-red-950 text-red-200 py-10 text-center\">\n    <div class=\"max-w-7xl mx-auto px-6\">\n      <div class=\"text-yellow-100 font-serif font-bold text-xl mb-2\">The Waypoint</div>\n      <p class=\"text-sm\">14 Main St, Wakefield RI 02879</p>\n      <p class=\"text-sm mt-1\">(401) 555-0384 · Tue–Sun · Dinner &amp; Sunday Brunch</p>\n      <p class=\"text-xs text-red-500 mt-4\">&copy; 2026 The Waypoint Restaurant. All rights reserved.</p>\n    </div>\n  </footer>\n\n</body>\n</html>\n",
