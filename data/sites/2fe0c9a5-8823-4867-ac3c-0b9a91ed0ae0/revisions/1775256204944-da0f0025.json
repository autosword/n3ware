{
  "id": "1775256204944-da0f0025",
  "siteId": "2fe0c9a5-8823-4867-ac3c-0b9a91ed0ae0",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Pawfect Care — Pet Grooming &amp; Dog Walking, South County RI</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <style>\n    .hero-bg { background-image: url('https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=1600&q=80'); background-size: cover; background-position: center; }\n    .card-hover { transition: transform 0.2s ease, box-shadow 0.2s ease; }\n    .card-hover:hover { transform: translateY(-4px); box-shadow: 0 16px 36px rgba(0,0,0,0.12); }\n  </style>\n</head>\n<body class=\"font-sans antialiased text-gray-800\" style=\"background-color:#fef3c7;\">\n\n  <!-- Nav -->\n  <nav class=\"sticky top-0 z-50 bg-white border-b border-teal-100 shadow-sm\">\n    <div class=\"max-w-7xl mx-auto px-6 py-4 flex items-center justify-between\">\n      <div class=\"flex items-center gap-2\">\n        <span class=\"text-2xl\">🐾</span>\n        <span class=\"text-teal-700 font-extrabold text-xl tracking-tight\">Pawfect Care</span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-8 text-sm font-medium\">\n        <a href=\"#services\" class=\"text-gray-600 hover:text-teal-700 transition-colors\">Services</a>\n        <a href=\"#pricing\" class=\"text-gray-600 hover:text-teal-700 transition-colors\">Pricing</a>\n        <a href=\"#team\" class=\"text-gray-600 hover:text-teal-700 transition-colors\">Our Team</a>\n        <a href=\"#book\" class=\"text-gray-600 hover:text-teal-700 transition-colors\">Book</a>\n      </div>\n      <a href=\"#book\" class=\"bg-teal-600 hover:bg-teal-700 text-white px-5 py-2 rounded-lg font-semibold text-sm transition-colors\">Book Now</a>\n    </div>\n  </nav>\n\n  <!-- Hero -->\n  <section class=\"hero-bg relative min-h-screen flex items-center justify-center\">\n    <div class=\"absolute inset-0 bg-teal-950/60\"></div>\n    <div class=\"relative z-10 text-center px-6 max-w-3xl mx-auto\">\n      <span class=\"inline-block bg-teal-600/70 text-teal-100 text-xs font-semibold uppercase tracking-widest px-4 py-1 rounded-full mb-5\">South County Rhode Island</span>\n      <h1 class=\"text-6xl font-extrabold text-white leading-tight mb-5\">Your Pet Deserves<br /><span class=\"text-teal-300\">the Best.</span></h1>\n      <p class=\"text-gray-200 text-xl mb-8 leading-relaxed\">Certified groomers and experienced walkers who treat every pet like family. Serving Wakefield, Narragansett, and all of South County since 2014.</p>\n      <div class=\"flex flex-wrap justify-center gap-4\">\n        <a href=\"#book\" class=\"bg-teal-500 hover:bg-teal-600 text-white px-8 py-3 rounded-lg font-bold text-lg transition-colors\">Book an Appointment</a>\n        <a href=\"#services\" class=\"border-2 border-white text-white hover:bg-white hover:text-teal-800 px-8 py-3 rounded-lg font-bold text-lg transition-colors\">Our Services</a>\n      </div>\n    </div>\n  </section>\n\n  <!-- Services -->\n  <section id=\"services\" class=\"py-20 bg-white\">\n    <div class=\"max-w-6xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-bold text-teal-800 text-center mb-3\">What We Offer</h2>\n      <p class=\"text-center text-gray-400 mb-12\">Professional care for dogs and cats of all breeds and sizes</p>\n      <div class=\"grid sm:grid-cols-2 md:grid-cols-4 gap-6\">\n        <div class=\"card-hover bg-teal-50 border border-teal-100 rounded-2xl p-6 text-center\">\n          <div class=\"w-14 h-14 bg-teal-600 text-white rounded-full flex items-center justify-center text-2xl mx-auto mb-4\">✂️</div>\n          <h3 class=\"font-bold text-teal-800 text-lg mb-2\">Grooming</h3>\n          <p class=\"text-gray-500 text-sm leading-relaxed\">Full bath, breed-specific haircut, nail trimming, ear cleaning, and blueberry facial. Your pup leaves looking fabulous.</p>\n        </div>\n        <div class=\"card-hover bg-teal-50 border border-teal-100 rounded-2xl p-6 text-center\">\n          <div class=\"w-14 h-14 bg-teal-600 text-white rounded-full flex items-center justify-center text-2xl mx-auto mb-4\">🦮</div>\n          <h3 class=\"font-bold text-teal-800 text-lg mb-2\">Dog Walking</h3>\n          <p class=\"text-gray-500 text-sm leading-relaxed\">30 or 60-minute walks with GPS tracking and photo updates. Solo or small group walks in your neighborhood.</p>\n        </div>\n        <div class=\"card-hover bg-teal-50 border border-teal-100 rounded-2xl p-6 text-center\">\n          <div class=\"w-14 h-14 bg-teal-600 text-white rounded-full flex items-center justify-center text-2xl mx-auto mb-4\">🏠</div>\n          <h3 class=\"font-bold text-teal-800 text-lg mb-2\">Pet Sitting</h3>\n          <p class=\"text-gray-500 text-sm leading-relaxed\">In-home overnight stays or drop-in visits. Your pet stays comfortable in their own home while you're away.</p>\n        </div>\n        <div class=\"card-hover bg-teal-50 border border-teal-100 rounded-2xl p-6 text-center\">\n          <div class=\"w-14 h-14 bg-teal-600 text-white rounded-full flex items-center justify-center text-2xl mx-auto mb-4\">💅</div>\n          <h3 class=\"font-bold text-teal-800 text-lg mb-2\">Nail Trimming</h3>\n          <p class=\"text-gray-500 text-sm leading-relaxed\">Quick standalone nail trim — no appointment needed. In and out in under 15 minutes. Walk-ins always welcome.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Pricing -->\n  <section id=\"pricing\" class=\"py-20\" style=\"background-color:#fef3c7;\">\n    <div class=\"max-w-6xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-bold text-teal-800 text-center mb-3\">Grooming Packages</h2>\n      <p class=\"text-center text-gray-500 mb-12\">All packages include a complimentary bandana and pet-safe spritz</p>\n      <div class=\"grid md:grid-cols-3 gap-6 mb-8\">\n        <!-- Basic -->\n        <div class=\"bg-white rounded-2xl border-2 border-gray-200 p-7\">\n          <h3 class=\"text-xl font-bold text-gray-800 mb-1\">Basic</h3>\n          <p class=\"text-gray-400 text-sm mb-4\">Bath, brush &amp; nail trim</p>\n          <div class=\"space-y-2 text-sm text-gray-600 mb-6\">\n            <div class=\"flex justify-between\"><span>Small (up to 25 lbs)</span><span class=\"font-bold text-teal-700\">$45</span></div>\n            <div class=\"flex justify-between\"><span>Medium (26–60 lbs)</span><span class=\"font-bold text-teal-700\">$55</span></div>\n            <div class=\"flex justify-between\"><span>Large (61+ lbs)</span><span class=\"font-bold text-teal-700\">$65</span></div>\n          </div>\n          <ul class=\"text-xs text-gray-400 space-y-1 mb-6\">\n            <li class=\"flex gap-2\"><span class=\"text-teal-500\">✓</span> Shampoo &amp; conditioning</li>\n            <li class=\"flex gap-2\"><span class=\"text-teal-500\">✓</span> Brush-out &amp; blowdry</li>\n            <li class=\"flex gap-2\"><span class=\"text-teal-500\">✓</span> Nail trim</li>\n          </ul>\n          <a href=\"#book\" class=\"block text-center border-2 border-teal-600 text-teal-600 hover:bg-teal-600 hover:text-white py-2 rounded-lg font-semibold text-sm transition-colors\">Book Basic</a>\n        </div>\n        <!-- Premium -->\n        <div class=\"bg-white rounded-2xl border-2 border-teal-500 p-7 relative shadow-lg\">\n          <span class=\"absolute -top-3 left-1/2 -translate-x-1/2 bg-teal-600 text-white text-xs font-bold px-4 py-1 rounded-full\">Most Popular</span>\n          <h3 class=\"text-xl font-bold text-gray-800 mb-1\">Premium</h3>\n          <p class=\"text-gray-400 text-sm mb-4\">Full groom + all styling</p>\n          <div class=\"space-y-2 text-sm text-gray-600 mb-6\">\n            <div class=\"flex justify-between\"><span>Small (up to 25 lbs)</span><span class=\"font-bold text-teal-700\">$75</span></div>\n            <div class=\"flex justify-between\"><span>Medium (26–60 lbs)</span><span class=\"font-bold text-teal-700\">$90</span></div>\n            <div class=\"flex justify-between\"><span>Large (61+ lbs)</span><span class=\"font-bold text-teal-700\">$105</span></div>\n          </div>\n          <ul class=\"text-xs text-gray-400 space-y-1 mb-6\">\n            <li class=\"flex gap-2\"><span class=\"text-teal-500\">✓</span> Everything in Basic</li>\n            <li class=\"flex gap-2\"><span class=\"text-teal-500\">✓</span> Breed-specific haircut</li>\n            <li class=\"flex gap-2\"><span class=\"text-teal-500\">✓</span> Ear cleaning</li>\n            <li class=\"flex gap-2\"><span class=\"text-teal-500\">✓</span> Paw balm treatment</li>\n          </ul>\n          <a href=\"#book\" class=\"block text-center bg-teal-600 hover:bg-teal-700 text-white py-2 rounded-lg font-semibold text-sm transition-colors\">Book Premium</a>\n        </div>\n        <!-- VIP -->\n        <div class=\"bg-white rounded-2xl border-2 border-gray-200 p-7\">\n          <h3 class=\"text-xl font-bold text-gray-800 mb-1\">VIP</h3>\n          <p class=\"text-gray-400 text-sm mb-4\">Premium + teeth &amp; accessories</p>\n          <div class=\"space-y-2 text-sm text-gray-600 mb-6\">\n            <div class=\"flex justify-between\"><span>Small (up to 25 lbs)</span><span class=\"font-bold text-teal-700\">$99</span></div>\n            <div class=\"flex justify-between\"><span>Medium (26–60 lbs)</span><span class=\"font-bold text-teal-700\">$119</span></div>\n            <div class=\"flex justify-between\"><span>Large (61+ lbs)</span><span class=\"font-bold text-teal-700\">$139</span></div>\n          </div>\n          <ul class=\"text-xs text-gray-400 space-y-1 mb-6\">\n            <li class=\"flex gap-2\"><span class=\"text-teal-500\">✓</span> Everything in Premium</li>\n            <li class=\"flex gap-2\"><span class=\"text-teal-500\">✓</span> Teeth brushing</li>\n            <li class=\"flex gap-2\"><span class=\"text-teal-500\">✓</span> Bandana or bow</li>\n            <li class=\"flex gap-2\"><span class=\"text-teal-500\">✓</span> Pawdicure nail polish</li>\n          </ul>\n          <a href=\"#book\" class=\"block text-center border-2 border-teal-600 text-teal-600 hover:bg-teal-600 hover:text-white py-2 rounded-lg font-semibold text-sm transition-colors\">Book VIP</a>\n        </div>\n      </div>\n      <!-- Add-ons -->\n      <div class=\"bg-teal-700 text-white rounded-2xl p-6 text-center\">\n        <h4 class=\"font-bold text-lg mb-3\">Add-On Services</h4>\n        <div class=\"flex flex-wrap justify-center gap-6 text-sm\">\n          <span><strong>Dog Walking</strong> — $25 / 30 min &nbsp;·&nbsp; $40 / 60 min</span>\n          <span><strong>Overnight Pet Sitting</strong> — $75 / night</span>\n          <span><strong>Drop-In Visit</strong> — $25 / visit</span>\n          <span><strong>Nail Trim Only</strong> — $18</span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Meet the Team -->\n  <section id=\"team\" class=\"py-20 bg-white\">\n    <div class=\"max-w-5xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-bold text-teal-800 text-center mb-3\">Meet the Team</h2>\n      <p class=\"text-center text-gray-400 mb-12\">Certified, background-checked, and genuinely obsessed with animals</p>\n      <div class=\"grid md:grid-cols-3 gap-8\">\n        <div class=\"card-hover text-center\">\n          <img src=\"https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=300&q=80\" alt=\"Casey\" class=\"w-28 h-28 rounded-full object-cover mx-auto mb-4 border-4 border-teal-200\" />\n          <h3 class=\"font-bold text-lg text-gray-900\">Casey Nowak</h3>\n          <p class=\"text-teal-600 text-sm font-medium\">Lead Groomer &amp; Owner</p>\n          <p class=\"text-gray-400 text-sm mt-2 leading-relaxed\">Certified master groomer with 11 years of experience. Casey grew up in South Kingstown and has groomed everything from Chihuahuas to Great Danes. Specializes in doodle and double-coat breeds.</p>\n        </div>\n        <div class=\"card-hover text-center\">\n          <img src=\"https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=300&q=80\" alt=\"Riley\" class=\"w-28 h-28 rounded-full object-cover mx-auto mb-4 border-4 border-teal-200\" />\n          <h3 class=\"font-bold text-lg text-gray-900\">Riley Santos</h3>\n          <p class=\"text-teal-600 text-sm font-medium\">Groomer &amp; Dog Walker</p>\n          <p class=\"text-gray-400 text-sm mt-2 leading-relaxed\">Animal science graduate from URI. Riley handles all dog walking routes in Wakefield and Narragansett and is certified in pet first aid &amp; CPR. Every walk includes GPS tracking and a photo update.</p>\n        </div>\n        <div class=\"card-hover text-center\">\n          <img src=\"https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=300&q=80\" alt=\"Marcus\" class=\"w-28 h-28 rounded-full object-cover mx-auto mb-4 border-4 border-teal-200\" />\n          <h3 class=\"font-bold text-lg text-gray-900\">Marcus Webb</h3>\n          <p class=\"text-teal-600 text-sm font-medium\">Pet Sitter &amp; Walker</p>\n          <p class=\"text-gray-400 text-sm mt-2 leading-relaxed\">Westerly native and lifelong dog lover. Marcus specializes in overnight pet sitting and has cared for over 80 families' pets. Clients say their dogs actually get excited when they see his car pull up.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Pet Gallery -->\n  <section class=\"py-20\" style=\"background-color:#fef3c7;\">\n    <div class=\"max-w-6xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-bold text-teal-800 text-center mb-12\">Our Happy Clients 🐾</h2>\n      <div class=\"grid grid-cols-2 md:grid-cols-3 gap-4\">\n        <img src=\"https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=400&q=80\" alt=\"Dog\" class=\"rounded-2xl w-full h-48 object-cover\" />\n        <img src=\"https://images.unsplash.com/photo-1552053831-71594a27632d?w=400&q=80\" alt=\"Dog\" class=\"rounded-2xl w-full h-48 object-cover\" />\n        <img src=\"https://images.unsplash.com/photo-1561037404-61cd46aa615b?w=400&q=80\" alt=\"Dog\" class=\"rounded-2xl w-full h-48 object-cover\" />\n        <img src=\"https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=400&q=80\" alt=\"Cat\" class=\"rounded-2xl w-full h-48 object-cover brightness-110\" />\n        <img src=\"https://images.unsplash.com/photo-1552053831-71594a27632d?w=400&q=80\" alt=\"Dog\" class=\"rounded-2xl w-full h-48 object-cover brightness-105\" />\n        <img src=\"https://images.unsplash.com/photo-1561037404-61cd46aa615b?w=400&q=80\" alt=\"Dog\" class=\"rounded-2xl w-full h-48 object-cover brightness-110\" />\n      </div>\n    </div>\n  </section>\n\n  <!-- Reviews -->\n  <section class=\"py-20 bg-white\">\n    <div class=\"max-w-5xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-bold text-teal-800 text-center mb-12\">Happy Pets &amp; Happy Owners</h2>\n      <div class=\"grid md:grid-cols-3 gap-6\">\n        <div class=\"bg-teal-50 rounded-2xl p-6 border border-teal-100\">\n          <div class=\"text-yellow-400 text-lg mb-3\">★★★★★</div>\n          <p class=\"text-gray-500 text-sm italic mb-4\">\"Biscuit came home looking like a show dog! Casey took so much care with his coat and he was completely calm and happy. We'll never go anywhere else. Best groomer in South County, hands down.\"</p>\n          <div class=\"text-sm font-semibold text-gray-700\">— Amanda K. &amp; Biscuit (Golden Retriever), Narragansett</div>\n        </div>\n        <div class=\"bg-teal-50 rounded-2xl p-6 border border-teal-100\">\n          <div class=\"text-yellow-400 text-lg mb-3\">★★★★★</div>\n          <p class=\"text-gray-500 text-sm italic mb-4\">\"Riley walks our two labs every day and sends the cutest photos. Luna and Bear absolutely adore her. The GPS tracking gives us peace of mind while we're at work. Worth every penny.\"</p>\n          <div class=\"text-sm font-semibold text-gray-700\">— Chris &amp; Dana F. (Luna &amp; Bear), Wakefield</div>\n        </div>\n        <div class=\"bg-teal-50 rounded-2xl p-6 border border-teal-100\">\n          <div class=\"text-yellow-400 text-lg mb-3\">★★★★★</div>\n          <p class=\"text-gray-500 text-sm italic mb-4\">\"Marcus stayed with Pepper for a whole week while we were in Maine and sent updates every morning. When we came home she was perfectly calm and happy. He's officially part of the family.\"</p>\n          <div class=\"text-sm font-semibold text-gray-700\">— Gina M. &amp; Pepper (Beagle mix), South Kingstown</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Booking Form -->\n  <section id=\"book\" class=\"py-20 bg-teal-700 text-white\">\n    <div class=\"max-w-2xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-bold text-center mb-3\">Book an Appointment</h2>\n      <p class=\"text-center text-teal-200 mb-8\">We'll confirm within 24 hours. For same-day availability, call us directly at <a href=\"tel:4015550412\" class=\"underline font-bold\">(401) 555-0412</a></p>\n      <form class=\"bg-white text-gray-800 rounded-2xl p-8 space-y-5\">\n        <div class=\"grid md:grid-cols-2 gap-5\">\n          <div>\n            <label class=\"block text-sm font-medium text-gray-700 mb-1\">Your Name</label>\n            <input type=\"text\" placeholder=\"Full name\" class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500\" />\n          </div>\n          <div>\n            <label class=\"block text-sm font-medium text-gray-700 mb-1\">Phone</label>\n            <input type=\"tel\" placeholder=\"(401) 555-0000\" class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500\" />\n          </div>\n        </div>\n        <div class=\"grid md:grid-cols-2 gap-5\">\n          <div>\n            <label class=\"block text-sm font-medium text-gray-700 mb-1\">Pet's Name</label>\n            <input type=\"text\" placeholder=\"What's their name?\" class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500\" />\n          </div>\n          <div>\n            <label class=\"block text-sm font-medium text-gray-700 mb-1\">Breed</label>\n            <input type=\"text\" placeholder=\"e.g. Golden Retriever, Tabby...\" class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500\" />\n          </div>\n        </div>\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700 mb-1\">Service</label>\n          <select class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500\">\n            <option>Basic Grooming</option>\n            <option>Premium Grooming</option>\n            <option>VIP Grooming</option>\n            <option>Dog Walking (30 min)</option>\n            <option>Dog Walking (60 min)</option>\n            <option>Pet Sitting — Overnight</option>\n            <option>Pet Sitting — Drop-In</option>\n            <option>Nail Trim Only</option>\n          </select>\n        </div>\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700 mb-1\">Preferred Date</label>\n          <input type=\"date\" class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500\" />\n        </div>\n        <button type=\"submit\" class=\"w-full bg-teal-600 hover:bg-teal-700 text-white py-3 rounded-lg font-bold transition-colors\">Request Booking</button>\n      </form>\n    </div>\n  </section>\n\n  <!-- Footer -->\n  <footer class=\"bg-teal-900 text-teal-200 py-10 text-center\">\n    <div class=\"max-w-7xl mx-auto px-6\">\n      <div class=\"text-white font-bold text-xl mb-2\">🐾 Pawfect Care</div>\n      <p class=\"text-sm\">Wakefield · Narragansett · South Kingstown · Westerly · Charlestown, RI</p>\n      <p class=\"text-sm mt-1\">Licensed &amp; Insured · (401) 555-0412</p>\n      <p class=\"text-xs text-teal-500 mt-4\">&copy; 2026 Pawfect Care. All rights reserved.</p>\n    </div>\n  </footer>\n\n</body>\n</html>\n",
