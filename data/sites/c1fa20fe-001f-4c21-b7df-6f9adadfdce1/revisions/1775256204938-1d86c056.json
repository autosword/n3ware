  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Green Thumb Lawn Care — South County RI</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <style>\n    .hero-bg { background-image: url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1600&q=80'); background-size: cover; background-position: center; }\n    .card-hover { transition: transform 0.2s ease, box-shadow 0.2s ease; }\n    .card-hover:hover { transform: translateY(-4px); box-shadow: 0 16px 36px rgba(0,0,0,0.12); }\n  </style>\n</head>\n<body class=\"font-sans antialiased bg-white text-gray-800\">\n\n  <!-- Nav -->\n  <nav class=\"sticky top-0 z-50 bg-white border-b border-gray-100 shadow-sm\">\n    <div class=\"max-w-7xl mx-auto px-6 py-4 flex items-center justify-between\">\n      <div class=\"flex items-center gap-2\">\n        <span class=\"text-green-700 text-2xl\">🌿</span>\n        <span class=\"text-green-800 font-extrabold text-xl tracking-tight\">Green Thumb Lawn Care</span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-8 text-sm font-medium\">\n        <a href=\"#services\" class=\"text-gray-600 hover:text-green-700 transition-colors\">Services</a>\n        <a href=\"#pricing\" class=\"text-gray-600 hover:text-green-700 transition-colors\">Pricing</a>\n        <a href=\"#gallery\" class=\"text-gray-600 hover:text-green-700 transition-colors\">Gallery</a>\n        <a href=\"#contact\" class=\"text-gray-600 hover:text-green-700 transition-colors\">Contact</a>\n      </div>\n      <a href=\"#contact\" class=\"bg-green-700 hover:bg-green-800 text-white px-5 py-2 rounded-lg font-semibold text-sm transition-colors\">Free Quote</a>\n    </div>\n  </nav>\n\n  <!-- Seasonal Banner -->\n  <div class=\"bg-green-700 text-white text-center py-3 text-sm font-semibold tracking-wide\">\n    🌿 Spring Cleanup Special — Book by April 30, Save 20% — Call <a href=\"tel:4015550247\" class=\"underline font-bold\">(401) 555-0247</a>\n  </div>\n\n  <!-- Hero -->\n  <section class=\"hero-bg relative min-h-screen flex items-center justify-center\">\n    <div class=\"absolute inset-0 bg-black/60\"></div>\n    <div class=\"relative z-10 text-center px-6 max-w-3xl mx-auto\">\n      <span class=\"inline-block bg-green-700/80 text-green-100 text-xs font-semibold uppercase tracking-widest px-4 py-1 rounded-full mb-4\">South County Rhode Island</span>\n      <h1 class=\"text-6xl font-extrabold text-white leading-tight mb-5\">Your Lawn,<br /><span class=\"text-green-400\">Our Passion.</span></h1>\n      <p class=\"text-gray-200 text-xl mb-8 leading-relaxed\">Professional lawn care and landscaping serving South Kingstown, Narragansett, Westerly &amp; surrounding towns since 2009. Locally owned, fully insured.</p>\n      <div class=\"flex flex-wrap justify-center gap-4\">\n        <a href=\"#contact\" class=\"bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-lg font-bold text-lg transition-colors\">Get Free Quote</a>\n        <a href=\"#services\" class=\"border-2 border-white text-white hover:bg-white hover:text-green-800 px-8 py-3 rounded-lg font-bold text-lg transition-colors\">Our Services</a>\n      </div>\n    </div>\n  </section>\n\n  <!-- Services Grid -->\n  <section id=\"services\" class=\"py-20 bg-gray-50\">\n    <div class=\"max-w-7xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-bold text-green-800 text-center mb-3\">What We Do</h2>\n      <p class=\"text-center text-gray-500 mb-12\">Full-service lawn and landscape care for residential and commercial properties</p>\n      <div class=\"grid sm:grid-cols-2 md:grid-cols-3 gap-6\">\n        <div class=\"card-hover bg-white rounded-2xl p-6 border border-gray-100 shadow-sm\">\n          <div class=\"text-4xl mb-3\">🌱</div>\n          <h3 class=\"font-bold text-green-800 text-lg mb-2\">Lawn Mowing</h3>\n          <p class=\"text-gray-500 text-sm mb-2\">Precision cuts for a clean, even lawn every time. Weekly or bi-weekly schedules available.</p>\n          <span class=\"text-green-700 font-bold text-sm\">Starting at $45/visit</span>\n        </div>\n        <div class=\"card-hover bg-white rounded-2xl p-6 border border-gray-100 shadow-sm\">\n          <div class=\"text-4xl mb-3\">✂️</div>\n          <h3 class=\"font-bold text-green-800 text-lg mb-2\">Edging &amp; Trimming</h3>\n          <p class=\"text-gray-500 text-sm mb-2\">Crisp edges along walkways, driveways, and garden beds to give your yard a polished finish.</p>\n          <span class=\"text-green-700 font-bold text-sm\">Included with mowing plans</span>\n        </div>\n        <div class=\"card-hover bg-white rounded-2xl p-6 border border-gray-100 shadow-sm\">\n          <div class=\"text-4xl mb-3\">🌿</div>\n          <h3 class=\"font-bold text-green-800 text-lg mb-2\">Fertilization &amp; Weed Control</h3>\n          <p class=\"text-gray-500 text-sm mb-2\">Seasonal programs that keep your lawn thick, green, and weed-free all year long.</p>\n          <span class=\"text-green-700 font-bold text-sm\">Seasonal programs available</span>\n        </div>\n        <div class=\"card-hover bg-white rounded-2xl p-6 border border-gray-100 shadow-sm\">\n          <div class=\"text-4xl mb-3\">🍂</div>\n          <h3 class=\"font-bold text-green-800 text-lg mb-2\">Leaf Cleanup</h3>\n          <p class=\"text-gray-500 text-sm mb-2\">Full fall cleanup — blowing, bagging, and hauling. Spring cleanups to uncover a healthy lawn.</p>\n          <span class=\"text-green-700 font-bold text-sm\">Seasonal service</span>\n        </div>\n        <div class=\"card-hover bg-white rounded-2xl p-6 border border-gray-100 shadow-sm\">\n          <div class=\"text-4xl mb-3\">❄️</div>\n          <h3 class=\"font-bold text-green-800 text-lg mb-2\">Snow Removal</h3>\n          <p class=\"text-gray-500 text-sm mb-2\">Reliable snow plowing and salting for driveways and walkways. Seasonal contracts available.</p>\n          <span class=\"text-green-700 font-bold text-sm\">Per event or seasonal</span>\n        </div>\n        <div class=\"card-hover bg-white rounded-2xl p-6 border border-gray-100 shadow-sm\">\n          <div class=\"text-4xl mb-3\">🪨</div>\n          <h3 class=\"font-bold text-green-800 text-lg mb-2\">Hardscaping &amp; Mulch</h3>\n          <p class=\"text-gray-500 text-sm mb-2\">Mulch installation, stone work, retaining walls, and garden bed design to transform your outdoor space.</p>\n          <span class=\"text-green-700 font-bold text-sm\">Free estimates</span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Pricing Table -->\n  <section id=\"pricing\" class=\"py-20 bg-white\">\n    <div class=\"max-w-5xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-bold text-green-800 text-center mb-3\">Simple, Clear Pricing</h2>\n      <p class=\"text-center text-gray-500 mb-12\">No hidden fees. Cancel anytime. All plans include licensed &amp; insured crew.</p>\n      <div class=\"grid md:grid-cols-3 gap-6\">\n        <!-- Basic -->\n        <div class=\"border-2 border-gray-200 rounded-2xl p-7\">\n          <h3 class=\"text-xl font-bold text-gray-800 mb-1\">Basic</h3>\n          <p class=\"text-gray-400 text-sm mb-4\">Mowing only</p>\n          <div class=\"text-3xl font-extrabold text-green-800 mb-1\">$45 <span class=\"text-lg font-normal text-gray-400\">/visit</span></div>\n          <div class=\"text-sm text-gray-500 mb-6\">or $160/month</div>\n          <ul class=\"space-y-2 text-sm text-gray-600 mb-7\">\n            <li class=\"flex gap-2\"><span class=\"text-green-600\">✓</span> Weekly or bi-weekly mowing</li>\n            <li class=\"flex gap-2\"><span class=\"text-green-600\">✓</span> Grass clippings bagged</li>\n            <li class=\"flex gap-2\"><span class=\"text-green-600\">✓</span> Blow off hard surfaces</li>\n          </ul>\n          <a href=\"#contact\" class=\"block text-center border-2 border-green-700 text-green-700 hover:bg-green-700 hover:text-white py-2 rounded-lg font-semibold text-sm transition-colors\">Get Started</a>\n        </div>\n        <!-- Standard -->\n        <div class=\"border-2 border-green-600 rounded-2xl p-7 relative shadow-lg\">\n          <span class=\"absolute -top-3 left-1/2 -translate-x-1/2 bg-green-600 text-white text-xs font-bold px-4 py-1 rounded-full\">Most Popular</span>\n          <h3 class=\"text-xl font-bold text-gray-800 mb-1\">Standard</h3>\n          <p class=\"text-gray-400 text-sm mb-4\">Mowing + edging + fertilization</p>\n          <div class=\"text-3xl font-extrabold text-green-800 mb-1\">$85 <span class=\"text-lg font-normal text-gray-400\">/visit</span></div>\n          <div class=\"text-sm text-gray-500 mb-6\">or $299/month</div>\n          <ul class=\"space-y-2 text-sm text-gray-600 mb-7\">\n            <li class=\"flex gap-2\"><span class=\"text-green-600\">✓</span> Everything in Basic</li>\n            <li class=\"flex gap-2\"><span class=\"text-green-600\">✓</span> Edging &amp; trimming</li>\n            <li class=\"flex gap-2\"><span class=\"text-green-600\">✓</span> Seasonal fertilization</li>\n            <li class=\"flex gap-2\"><span class=\"text-green-600\">✓</span> Weed control treatment</li>\n          </ul>\n          <a href=\"#contact\" class=\"block text-center bg-green-600 hover:bg-green-700 text-white py-2 rounded-lg font-semibold text-sm transition-colors\">Get Started</a>\n        </div>\n        <!-- Premium -->\n        <div class=\"border-2 border-gray-200 rounded-2xl p-7\">\n          <h3 class=\"text-xl font-bold text-gray-800 mb-1\">Premium</h3>\n          <p class=\"text-gray-400 text-sm mb-4\">Everything included</p>\n          <div class=\"text-3xl font-extrabold text-green-800 mb-1\">$149 <span class=\"text-lg font-normal text-gray-400\">/visit</span></div>\n          <div class=\"text-sm text-gray-500 mb-6\">or $499/month</div>\n          <ul class=\"space-y-2 text-sm text-gray-600 mb-7\">\n            <li class=\"flex gap-2\"><span class=\"text-green-600\">✓</span> Everything in Standard</li>\n            <li class=\"flex gap-2\"><span class=\"text-green-600\">✓</span> Leaf cleanup (spring &amp; fall)</li>\n            <li class=\"flex gap-2\"><span class=\"text-green-600\">✓</span> Mulch bed maintenance</li>\n            <li class=\"flex gap-2\"><span class=\"text-green-600\">✓</span> Priority scheduling</li>\n          </ul>\n          <a href=\"#contact\" class=\"block text-center border-2 border-green-700 text-green-700 hover:bg-green-700 hover:text-white py-2 rounded-lg font-semibold text-sm transition-colors\">Get Started</a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Before/After Gallery -->\n  <section id=\"gallery\" class=\"py-20 bg-stone-50\">\n    <div class=\"max-w-7xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-bold text-green-800 text-center mb-3\">Before &amp; After</h2>\n      <p class=\"text-center text-gray-500 mb-12\">Real results from real South County lawns</p>\n      <div class=\"grid md:grid-cols-3 gap-8\">\n        <div class=\"bg-white rounded-2xl overflow-hidden shadow-md\">\n          <div class=\"grid grid-cols-2 divide-x divide-gray-200\">\n            <div>\n              <div class=\"text-xs font-bold text-gray-500 bg-gray-100 px-2 py-1 text-center\">BEFORE</div>\n              <img src=\"https://images.unsplash.com/photo-1589923158776-cb4dc7b87dc7?w=400&q=80\" alt=\"Before\" class=\"w-full h-36 object-cover\" />\n            </div>\n            <div>\n              <div class=\"text-xs font-bold text-white bg-green-600 px-2 py-1 text-center\">AFTER</div>\n              <img src=\"https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400&q=80\" alt=\"After\" class=\"w-full h-36 object-cover\" />\n            </div>\n          </div>\n          <div class=\"p-4 text-center text-sm text-gray-600 font-medium\">South Kingstown backyard — full season cleanup</div>\n        </div>\n        <div class=\"bg-white rounded-2xl overflow-hidden shadow-md\">\n          <div class=\"grid grid-cols-2 divide-x divide-gray-200\">\n            <div>\n              <div class=\"text-xs font-bold text-gray-500 bg-gray-100 px-2 py-1 text-center\">BEFORE</div>\n              <img src=\"https://images.unsplash.com/photo-1589923158776-cb4dc7b87dc7?w=400&q=80\" alt=\"Before\" class=\"w-full h-36 object-cover\" />\n            </div>\n            <div>\n              <div class=\"text-xs font-bold text-white bg-green-600 px-2 py-1 text-center\">AFTER</div>\n              <img src=\"https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400&q=80\" alt=\"After\" class=\"w-full h-36 object-cover\" />\n            </div>\n          </div>\n          <div class=\"p-4 text-center text-sm text-gray-600 font-medium\">Narragansett front yard — edging &amp; mulch</div>\n        </div>\n        <div class=\"bg-white rounded-2xl overflow-hidden shadow-md\">\n          <div class=\"grid grid-cols-2 divide-x divide-gray-200\">\n            <div>\n              <div class=\"text-xs font-bold text-gray-500 bg-gray-100 px-2 py-1 text-center\">BEFORE</div>\n              <img src=\"https://images.unsplash.com/photo-1589923158776-cb4dc7b87dc7?w=400&q=80\" alt=\"Before\" class=\"w-full h-36 object-cover\" />\n            </div>\n            <div>\n              <div class=\"text-xs font-bold text-white bg-green-600 px-2 py-1 text-center\">AFTER</div>\n              <img src=\"https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400&q=80\" alt=\"After\" class=\"w-full h-36 object-cover\" />\n            </div>\n          </div>\n          <div class=\"p-4 text-center text-sm text-gray-600 font-medium\">Westerly lawn — fertilization &amp; weed control</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Service Area -->\n  <section class=\"py-12 bg-green-800 text-white text-center\">\n    <div class=\"max-w-4xl mx-auto px-6\">\n      <h3 class=\"text-2xl font-bold mb-3\">Service Area</h3>\n      <p class=\"text-green-200 text-lg\">Proudly serving <strong class=\"text-white\">South Kingstown · Narragansett · Wakefield · Westerly · Charlestown · North Kingstown</strong> and surrounding South County communities.</p>\n    </div>\n  </section>\n\n  <!-- Reviews -->\n  <section class=\"py-20 bg-white\">\n    <div class=\"max-w-5xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-bold text-green-800 text-center mb-12\">Happy Customers</h2>\n      <div class=\"grid md:grid-cols-3 gap-6\">\n        <div class=\"bg-gray-50 rounded-2xl p-6 border border-gray-100\">\n          <div class=\"text-yellow-400 text-lg mb-3\">★★★★★</div>\n          <p class=\"text-gray-600 text-sm italic mb-4\">\"Green Thumb transformed our Wakefield yard. Shows up on time, does a meticulous job, and the price is very fair. We've been customers for 3 seasons now.\"</p>\n          <div class=\"text-sm font-semibold text-gray-700\">— Bob &amp; Diane R., Wakefield RI</div>\n        </div>\n        <div class=\"bg-gray-50 rounded-2xl p-6 border border-gray-100\">\n          <div class=\"text-yellow-400 text-lg mb-3\">★★★★★</div>\n          <p class=\"text-gray-600 text-sm italic mb-4\">\"They did our spring cleanup and the yard looked brand new. The edging alone made our Narragansett property look like it belongs on a magazine cover.\"</p>\n          <div class=\"text-sm font-semibold text-gray-700\">— Linda S., Narragansett RI</div>\n        </div>\n        <div class=\"bg-gray-50 rounded-2xl p-6 border border-gray-100\">\n          <div class=\"text-yellow-400 text-lg mb-3\">★★★★★</div>\n          <p class=\"text-gray-600 text-sm italic mb-4\">\"Super responsive and professional. The mulch and stone work they did in our backyard in Charlestown got compliments from every neighbor. Highly recommend.\"</p>\n          <div class=\"text-sm font-semibold text-gray-700\">— Tom F., Charlestown RI</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Quote Form -->\n  <section id=\"contact\" class=\"py-20 bg-green-50\">\n    <div class=\"max-w-2xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-bold text-green-800 text-center mb-3\">Get Your Free Quote</h2>\n      <p class=\"text-center text-gray-500 mb-8\">No obligation — we'll come out and assess your property at no charge.</p>\n      <form class=\"bg-white rounded-2xl p-8 shadow-md space-y-5\">\n        <div class=\"grid md:grid-cols-2 gap-5\">\n          <div>\n            <label class=\"block text-sm font-medium text-gray-700 mb-1\">Full Name</label>\n            <input type=\"text\" placeholder=\"Your name\" class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-600\" />\n          </div>\n          <div>\n            <label class=\"block text-sm font-medium text-gray-700 mb-1\">Phone</label>\n            <input type=\"tel\" placeholder=\"(401) 555-0000\" class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-600\" />\n          </div>\n        </div>\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700 mb-1\">Property Address</label>\n          <input type=\"text\" placeholder=\"Street address, town, RI\" class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-600\" />\n        </div>\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700 mb-1\">Service Needed</label>\n          <select class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-600\">\n            <option>Lawn Mowing</option>\n            <option>Spring/Fall Cleanup</option>\n            <option>Fertilization &amp; Weed Control</option>\n            <option>Mulch &amp; Hardscaping</option>\n            <option>Snow Removal</option>\n            <option>Full Service Plan</option>\n          </select>\n        </div>\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700 mb-1\">Additional Notes</label>\n          <textarea rows=\"3\" placeholder=\"Describe your lawn or any specific needs...\" class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-600\"></textarea>\n        </div>\n        <button type=\"submit\" class=\"w-full bg-green-700 hover:bg-green-800 text-white py-3 rounded-lg font-bold transition-colors\">Request Free Quote</button>\n      </form>\n    </div>\n  </section>\n\n  <!-- Footer -->\n  <footer class=\"bg-green-900 text-green-200 py-10 text-center\">\n    <div class=\"max-w-7xl mx-auto px-6\">\n      <div class=\"text-white font-bold text-lg mb-2\">🌿 Green Thumb Lawn Care</div>\n      <p class=\"text-sm\">South Kingstown · Narragansett · Wakefield · Westerly · Charlestown · North Kingstown, RI</p>\n      <p class=\"text-sm mt-1\">Licensed &amp; Insured · (401) 555-0247</p>\n      <p class=\"text-xs text-green-500 mt-4\">&copy; 2026 Green Thumb Lawn Care. All rights reserved.</p>\n    </div>\n  </footer>\n\n</body>\n</html>\n",
