  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>South County Homes — Your Local Real Estate Expert</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <style>\n    .stat-badge { backdrop-filter: blur(8px); }\n    .card-hover { transition: transform 0.2s ease, box-shadow 0.2s ease; }\n    .card-hover:hover { transform: translateY(-4px); box-shadow: 0 20px 40px rgba(0,0,0,0.15); }\n  </style>\n</head>\n<body class=\"font-sans antialiased bg-white text-gray-800\">\n\n  <!-- Sticky Nav -->\n  <nav class=\"sticky top-0 z-50 bg-[#1e3a5f] shadow-lg\">\n    <div class=\"max-w-7xl mx-auto px-6 py-4 flex items-center justify-between\">\n      <div class=\"flex items-center gap-2\">\n        <span class=\"text-[#d97706] text-2xl\">⌂</span>\n        <span class=\"text-white font-bold text-xl tracking-tight\">South County Homes</span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-8 text-sm font-medium\">\n        <a href=\"#listings\" class=\"text-gray-300 hover:text-[#d97706] transition-colors\">Listings</a>\n        <a href=\"#about\" class=\"text-gray-300 hover:text-[#d97706] transition-colors\">About</a>\n        <a href=\"#market\" class=\"text-gray-300 hover:text-[#d97706] transition-colors\">Market Stats</a>\n        <a href=\"#contact\" class=\"text-gray-300 hover:text-[#d97706] transition-colors\">Contact</a>\n      </div>\n      <a href=\"#contact\" class=\"bg-[#d97706] hover:bg-amber-600 text-white px-5 py-2 rounded-lg font-semibold text-sm transition-colors\">Contact Me</a>\n    </div>\n  </nav>\n\n  <!-- Hero: Split Layout -->\n  <section class=\"bg-[#1e3a5f] min-h-screen flex items-center\">\n    <div class=\"max-w-7xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-16 items-center w-full\">\n      <!-- Left -->\n      <div>\n        <span class=\"inline-block bg-[#1e40af]/30 text-[#d97706] text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-4 border border-[#d97706]/40\">South County Real Estate</span>\n        <h1 class=\"text-5xl font-extrabold text-white leading-tight mb-5\">Your South County<br /><span class=\"text-[#d97706]\">Home Expert</span></h1>\n        <p class=\"text-blue-200 text-lg mb-8 leading-relaxed\">15+ years helping families find their perfect home in Wakefield, Narragansett &amp; Westerly. Local knowledge, personal service, proven results.</p>\n        <div class=\"flex flex-wrap gap-4\">\n          <a href=\"#listings\" class=\"bg-[#d97706] hover:bg-amber-600 text-white px-7 py-3 rounded-lg font-bold transition-colors\">View Listings</a>\n          <a href=\"#contact\" class=\"border-2 border-white text-white hover:bg-white hover:text-[#1e3a5f] px-7 py-3 rounded-lg font-bold transition-colors\">Free Home Valuation</a>\n        </div>\n      </div>\n      <!-- Right: Headshot + Badges -->\n      <div class=\"flex flex-col items-center gap-6\">\n        <div class=\"relative\">\n          <div class=\"w-64 h-64 rounded-full overflow-hidden border-4 border-[#d97706] shadow-2xl\">\n            <img src=\"https://images.unsplash.com/photo-1560250097-0b93528c311a?w=500&q=80\" alt=\"Real estate agent\" class=\"w-full h-full object-cover\" />\n          </div>\n          <div class=\"absolute -bottom-4 -right-4 bg-[#d97706] text-white text-xs font-bold px-3 py-2 rounded-full shadow-lg\">REALTOR®</div>\n        </div>\n        <div class=\"grid grid-cols-3 gap-4 w-full max-w-xs\">\n          <div class=\"stat-badge bg-white/10 border border-white/20 rounded-xl p-3 text-center\">\n            <div class=\"text-[#d97706] font-extrabold text-2xl\">150+</div>\n            <div class=\"text-blue-200 text-xs mt-1\">Homes Sold</div>\n          </div>\n          <div class=\"stat-badge bg-white/10 border border-white/20 rounded-xl p-3 text-center\">\n            <div class=\"text-[#d97706] font-extrabold text-xl\">$2.4M</div>\n            <div class=\"text-blue-200 text-xs mt-1\">Avg Sale</div>\n          </div>\n          <div class=\"stat-badge bg-white/10 border border-white/20 rounded-xl p-3 text-center\">\n            <div class=\"text-[#d97706] font-extrabold text-2xl\">98%</div>\n            <div class=\"text-blue-200 text-xs mt-1\">Satisfaction</div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Featured Listings -->\n  <section id=\"listings\" class=\"py-20 bg-gray-50\">\n    <div class=\"max-w-7xl mx-auto px-6\">\n      <div class=\"text-center mb-12\">\n        <h2 class=\"text-4xl font-bold text-[#1e3a5f] mb-3\">Featured Listings</h2>\n        <p class=\"text-gray-500 text-lg\">Handpicked properties across South County's most desirable neighborhoods</p>\n      </div>\n      <div class=\"grid md:grid-cols-3 gap-8\">\n        <!-- Card 1 -->\n        <div class=\"card-hover bg-white rounded-2xl overflow-hidden shadow-md border border-gray-100\">\n          <div class=\"relative\">\n            <img src=\"https://images.unsplash.com/photo-1568605114967-8130f3a36994?w=600&q=80\" alt=\"42 Ocean Rd\" class=\"w-full h-52 object-cover\" />\n            <span class=\"absolute top-3 left-3 bg-[#d97706] text-white text-xs font-bold px-3 py-1 rounded-full\">For Sale</span>\n          </div>\n          <div class=\"p-5\">\n            <div class=\"text-2xl font-extrabold text-[#1e3a5f] mb-1\">$485,000</div>\n            <div class=\"text-gray-600 font-medium mb-3\">42 Ocean Rd, Narragansett RI</div>\n            <div class=\"flex gap-4 text-gray-500 text-sm mb-4\">\n              <span>🛏 3 Beds</span>\n              <span>🚿 2 Baths</span>\n              <span>📐 1,840 sqft</span>\n            </div>\n            <button class=\"w-full bg-[#1e3a5f] hover:bg-[#1e40af] text-white py-2 rounded-lg font-semibold text-sm transition-colors\">View Details</button>\n          </div>\n        </div>\n        <!-- Card 2 -->\n        <div class=\"card-hover bg-white rounded-2xl overflow-hidden shadow-md border border-gray-100\">\n          <div class=\"relative\">\n            <img src=\"https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=600&q=80\" alt=\"18 Pine St\" class=\"w-full h-52 object-cover\" />\n            <span class=\"absolute top-3 left-3 bg-[#d97706] text-white text-xs font-bold px-3 py-1 rounded-full\">For Sale</span>\n          </div>\n          <div class=\"p-5\">\n            <div class=\"text-2xl font-extrabold text-[#1e3a5f] mb-1\">$392,000</div>\n            <div class=\"text-gray-600 font-medium mb-3\">18 Pine St, Wakefield RI</div>\n            <div class=\"flex gap-4 text-gray-500 text-sm mb-4\">\n              <span>🛏 3 Beds</span>\n              <span>🚿 2 Baths</span>\n              <span>📐 1,620 sqft</span>\n            </div>\n            <button class=\"w-full bg-[#1e3a5f] hover:bg-[#1e40af] text-white py-2 rounded-lg font-semibold text-sm transition-colors\">View Details</button>\n          </div>\n        </div>\n        <!-- Card 3 -->\n        <div class=\"card-hover bg-white rounded-2xl overflow-hidden shadow-md border border-gray-100\">\n          <div class=\"relative\">\n            <img src=\"https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=600&q=80\" alt=\"91 Atlantic Ave\" class=\"w-full h-52 object-cover\" />\n            <span class=\"absolute top-3 left-3 bg-green-600 text-white text-xs font-bold px-3 py-1 rounded-full\">New Listing</span>\n          </div>\n          <div class=\"p-5\">\n            <div class=\"text-2xl font-extrabold text-[#1e3a5f] mb-1\">$629,000</div>\n            <div class=\"text-gray-600 font-medium mb-3\">91 Atlantic Ave, Westerly RI</div>\n            <div class=\"flex gap-4 text-gray-500 text-sm mb-4\">\n              <span>🛏 4 Beds</span>\n              <span>🚿 3 Baths</span>\n              <span>📐 2,380 sqft</span>\n            </div>\n            <button class=\"w-full bg-[#1e3a5f] hover:bg-[#1e40af] text-white py-2 rounded-lg font-semibold text-sm transition-colors\">View Details</button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- About -->\n  <section id=\"about\" class=\"py-20 bg-white\">\n    <div class=\"max-w-4xl mx-auto px-6 text-center\">\n      <h2 class=\"text-4xl font-bold text-[#1e3a5f] mb-6\">About Me</h2>\n      <p class=\"text-gray-600 text-lg leading-relaxed mb-4\">Born and raised in South County, I've spent the past 15 years helping buyers and sellers navigate the Rhode Island real estate market with confidence. From the coastal neighborhoods of Narragansett to the charming village streets of Wakefield, I know every corner of our community — the hidden gems, the up-and-coming streets, and the homes that hold their value for decades.</p>\n      <p class=\"text-gray-600 text-lg leading-relaxed mb-6\">I specialize in residential real estate across Narragansett, South Kingstown, Westerly, Charlestown, and Wakefield. Whether you're a first-time buyer, relocating from out of state, or selling the family home, I'll guide you every step of the way.</p>\n      <div class=\"flex justify-center gap-4 flex-wrap\">\n        <span class=\"bg-[#1e3a5f] text-white px-4 py-2 rounded-full text-sm font-semibold\">CRS — Certified Residential Specialist</span>\n        <span class=\"bg-[#d97706] text-white px-4 py-2 rounded-full text-sm font-semibold\">ABR — Accredited Buyer's Representative</span>\n        <span class=\"bg-gray-700 text-white px-4 py-2 rounded-full text-sm font-semibold\">RI Licensed Realtor®</span>\n      </div>\n    </div>\n  </section>\n\n  <!-- Market Stats -->\n  <section id=\"market\" class=\"py-20 bg-[#1e3a5f]\">\n    <div class=\"max-w-7xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-bold text-white text-center mb-12\">South County Market Stats</h2>\n      <div class=\"grid grid-cols-2 md:grid-cols-4 gap-6\">\n        <div class=\"bg-white/10 border border-white/20 rounded-2xl p-6 text-center\">\n          <div class=\"text-[#d97706] text-4xl font-extrabold mb-2\">$450K</div>\n          <div class=\"text-blue-200 text-sm font-medium\">Median Home Price</div>\n        </div>\n        <div class=\"bg-white/10 border border-white/20 rounded-2xl p-6 text-center\">\n          <div class=\"text-[#d97706] text-4xl font-extrabold mb-2\">21</div>\n          <div class=\"text-blue-200 text-sm font-medium\">Avg Days on Market</div>\n        </div>\n        <div class=\"bg-white/10 border border-white/20 rounded-2xl p-6 text-center\">\n          <div class=\"text-[#d97706] text-4xl font-extrabold mb-2\">312</div>\n          <div class=\"text-blue-200 text-sm font-medium\">Homes Sold This Year</div>\n        </div>\n        <div class=\"bg-white/10 border border-white/20 rounded-2xl p-6 text-center\">\n          <div class=\"text-[#d97706] text-4xl font-extrabold mb-2\">103%</div>\n          <div class=\"text-blue-200 text-sm font-medium\">List-to-Sale Ratio</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Testimonials -->\n  <section class=\"py-20 bg-gray-50\">\n    <div class=\"max-w-5xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-bold text-[#1e3a5f] text-center mb-12\">What My Clients Say</h2>\n      <div class=\"grid md:grid-cols-2 gap-8\">\n        <div class=\"bg-white rounded-2xl p-8 shadow-md border border-gray-100\">\n          <div class=\"text-[#d97706] text-xl mb-4\">★★★★★</div>\n          <p class=\"text-gray-600 italic mb-6\">\"After years of renting in Providence, we finally made the leap to Narragansett. She knew every listing before it hit Zillow and got us into our dream home $15,000 under asking. We couldn't be happier with our little piece of South County.\"</p>\n          <div class=\"flex items-center gap-3\">\n            <div class=\"w-10 h-10 bg-[#1e3a5f] text-white rounded-full flex items-center justify-center font-bold text-sm\">JM</div>\n            <div>\n              <div class=\"font-semibold text-gray-800\">James & Maria T.</div>\n              <div class=\"text-gray-400 text-xs\">Narragansett, RI</div>\n            </div>\n          </div>\n        </div>\n        <div class=\"bg-white rounded-2xl p-8 shadow-md border border-gray-100\">\n          <div class=\"text-[#d97706] text-xl mb-4\">★★★★★</div>\n          <p class=\"text-gray-600 italic mb-6\">\"Selling my parents' home in Wakefield was emotional, but she made the process seamless. She priced it right, marketed it beautifully, and we had multiple offers within a week. Closed above asking at 106%. Truly exceptional.\"</p>\n          <div class=\"flex items-center gap-3\">\n            <div class=\"w-10 h-10 bg-[#d97706] text-white rounded-full flex items-center justify-center font-bold text-sm\">KP</div>\n            <div>\n              <div class=\"font-semibold text-gray-800\">Karen P.</div>\n              <div class=\"text-gray-400 text-xs\">Wakefield, RI</div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Contact -->\n  <section id=\"contact\" class=\"py-20 bg-white\">\n    <div class=\"max-w-3xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-bold text-[#1e3a5f] text-center mb-3\">Get In Touch</h2>\n      <p class=\"text-center text-gray-500 mb-4\">Ready to buy or sell? Call or fill out the form below.</p>\n      <p class=\"text-center text-2xl font-bold text-[#d97706] mb-10\"><a href=\"tel:4015550189\">(401) 555-0189</a></p>\n      <form class=\"space-y-5 bg-gray-50 p-8 rounded-2xl shadow-md\">\n        <div class=\"grid md:grid-cols-2 gap-5\">\n          <div>\n            <label class=\"block text-sm font-medium text-gray-700 mb-1\">Name</label>\n            <input type=\"text\" placeholder=\"Your full name\" class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#1e40af]\" />\n          </div>\n          <div>\n            <label class=\"block text-sm font-medium text-gray-700 mb-1\">Email</label>\n            <input type=\"email\" placeholder=\"you@email.com\" class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#1e40af]\" />\n          </div>\n        </div>\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700 mb-1\">Phone</label>\n          <input type=\"tel\" placeholder=\"(401) 555-0000\" class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#1e40af]\" />\n        </div>\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700 mb-1\">Message</label>\n          <textarea rows=\"4\" placeholder=\"Tell me what you're looking for...\" class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#1e40af]\"></textarea>\n        </div>\n        <button type=\"submit\" class=\"w-full bg-[#1e3a5f] hover:bg-[#1e40af] text-white py-3 rounded-lg font-bold transition-colors\">Send Message</button>\n      </form>\n    </div>\n  </section>\n\n  <!-- Footer -->\n  <footer class=\"bg-[#1e3a5f] text-blue-200 py-10 text-center\">\n    <div class=\"max-w-7xl mx-auto px-6\">\n      <div class=\"text-white font-bold text-lg mb-2\">South County Homes</div>\n      <p class=\"text-sm\">Serving Narragansett · South Kingstown · Westerly · Charlestown · Wakefield, RI</p>\n      <p class=\"text-sm mt-1\">Licensed in Rhode Island · (401) 555-0189</p>\n      <p class=\"text-xs text-blue-400 mt-4\">&copy; 2026 South County Homes. All rights reserved.</p>\n    </div>\n  </footer>\n\n</body>\n</html>\n",
