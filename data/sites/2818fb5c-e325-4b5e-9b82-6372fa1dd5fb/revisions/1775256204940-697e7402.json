  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>FixIt Pro — Licensed Handyman &amp; Trade Services, South County RI</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <style>\n    .hero-bg { background-image: url('https://images.unsplash.com/photo-1581244277943-fe4a9c777189?w=1600&q=80'); background-size: cover; background-position: center; }\n    .card-hover { transition: transform 0.2s ease; }\n    .card-hover:hover { transform: translateY(-3px); }\n  </style>\n</head>\n<body class=\"font-sans antialiased bg-white text-gray-800\">\n\n  <!-- Emergency Banner -->\n  <div class=\"bg-orange-600 text-white text-center py-3 px-6\">\n    <span class=\"text-base font-bold\">🚨 Emergency Service Available 24/7 — Call </span>\n    <a href=\"tel:4015550911\" class=\"text-2xl font-extrabold underline hover:text-orange-200 transition-colors\">(401) 555-0911</a>\n  </div>\n\n  <!-- Nav -->\n  <nav class=\"sticky top-0 z-50 bg-white border-b border-gray-200 shadow-sm\">\n    <div class=\"max-w-7xl mx-auto px-6 py-4 flex items-center justify-between\">\n      <div class=\"flex items-center gap-2\">\n        <span class=\"text-blue-700 text-2xl\">🔧</span>\n        <span class=\"text-blue-800 font-extrabold text-xl tracking-tight\">FixIt Pro</span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-8 text-sm font-medium\">\n        <a href=\"#services\" class=\"text-gray-600 hover:text-blue-700 transition-colors\">Services</a>\n        <a href=\"#area\" class=\"text-gray-600 hover:text-blue-700 transition-colors\">Service Area</a>\n        <a href=\"#reviews\" class=\"text-gray-600 hover:text-blue-700 transition-colors\">Reviews</a>\n        <a href=\"#contact\" class=\"text-gray-600 hover:text-blue-700 transition-colors\">Contact</a>\n      </div>\n      <a href=\"#contact\" class=\"bg-blue-700 hover:bg-blue-800 text-white px-5 py-2 rounded-lg font-semibold text-sm transition-colors\">Request Service</a>\n    </div>\n  </nav>\n\n  <!-- Hero -->\n  <section class=\"hero-bg relative min-h-screen flex items-center\">\n    <div class=\"absolute inset-0 bg-blue-950/70\"></div>\n    <div class=\"relative z-10 max-w-7xl mx-auto px-6 py-20\">\n      <span class=\"inline-block bg-orange-600 text-white text-xs font-bold uppercase tracking-widest px-4 py-1 rounded-full mb-5\">South County RI Since 2005</span>\n      <h1 class=\"text-6xl font-extrabold text-white leading-tight mb-5 max-w-2xl\">No Job<br /><span class=\"text-orange-400\">Too Small.</span></h1>\n      <p class=\"text-blue-200 text-xl mb-8 max-w-xl leading-relaxed\">Licensed, bonded &amp; insured. From a dripping faucet to a full bathroom remodel — we handle it all across South County since 2005.</p>\n      <div class=\"flex flex-wrap gap-4\">\n        <a href=\"tel:4015550911\" class=\"bg-orange-600 hover:bg-orange-700 text-white px-8 py-3 rounded-lg font-bold text-lg transition-colors\">🚨 Call Now — 24/7</a>\n        <a href=\"#contact\" class=\"border-2 border-white text-white hover:bg-white hover:text-blue-900 px-8 py-3 rounded-lg font-bold text-lg transition-colors\">Request a Quote</a>\n      </div>\n    </div>\n  </section>\n\n  <!-- Trust Badges -->\n  <section class=\"py-10 bg-blue-800\">\n    <div class=\"max-w-5xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-6 text-center\">\n      <div class=\"text-white\">\n        <div class=\"text-3xl mb-2\">✅</div>\n        <div class=\"font-bold text-sm\">Licensed &amp; Insured</div>\n        <div class=\"text-blue-300 text-xs\">RI Contractor Lic. #RC-04821</div>\n      </div>\n      <div class=\"text-white\">\n        <div class=\"text-3xl mb-2\">🏆</div>\n        <div class=\"font-bold text-sm\">10-Year Warranty</div>\n        <div class=\"text-blue-300 text-xs\">On all major installations</div>\n      </div>\n      <div class=\"text-white\">\n        <div class=\"text-3xl mb-2\">⭐</div>\n        <div class=\"font-bold text-sm\">500+ Reviews</div>\n        <div class=\"text-blue-300 text-xs\">4.9 stars on Google</div>\n      </div>\n      <div class=\"text-white\">\n        <div class=\"text-3xl mb-2\">🚨</div>\n        <div class=\"font-bold text-sm\">24/7 Emergency</div>\n        <div class=\"text-blue-300 text-xs\">Always available</div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Pricing Bar -->\n  <div class=\"bg-orange-50 border-y border-orange-200 py-5 text-center\">\n    <p class=\"text-orange-700 font-semibold text-base\">Service Call Starting at <strong>$75</strong> &nbsp;·&nbsp; Labor from <strong>$85/hr</strong> &nbsp;·&nbsp; Free Estimates on Projects Over $500</p>\n  </div>\n\n  <!-- Services -->\n  <section id=\"services\" class=\"py-20 bg-white\">\n    <div class=\"max-w-7xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-bold text-blue-800 text-center mb-3\">Our Services</h2>\n      <p class=\"text-center text-gray-500 mb-12\">Expert tradespeople for every project, big or small</p>\n      <div class=\"grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6\">\n        <div class=\"card-hover bg-blue-50 rounded-2xl p-6 border border-blue-100\">\n          <div class=\"text-3xl mb-3\">🔩</div>\n          <h3 class=\"font-bold text-blue-800 text-base mb-2\">Plumbing</h3>\n          <p class=\"text-gray-500 text-xs leading-relaxed\">Pipes, fixtures, leaks, drain clogs, water heaters, toilet repair &amp; installation.</p>\n        </div>\n        <div class=\"card-hover bg-blue-50 rounded-2xl p-6 border border-blue-100\">\n          <div class=\"text-3xl mb-3\">⚡</div>\n          <h3 class=\"font-bold text-blue-800 text-base mb-2\">Electrical</h3>\n          <p class=\"text-gray-500 text-xs leading-relaxed\">Outlets, panels, ceiling fans, lighting, GFCI, switch replacement, EV charger installation.</p>\n        </div>\n        <div class=\"card-hover bg-blue-50 rounded-2xl p-6 border border-blue-100\">\n          <div class=\"text-3xl mb-3\">🪚</div>\n          <h3 class=\"font-bold text-blue-800 text-base mb-2\">Carpentry</h3>\n          <p class=\"text-gray-500 text-xs leading-relaxed\">Doors, trim, crown molding, custom cabinets, decks, pergolas, and shelving.</p>\n        </div>\n        <div class=\"card-hover bg-blue-50 rounded-2xl p-6 border border-blue-100\">\n          <div class=\"text-3xl mb-3\">🖌️</div>\n          <h3 class=\"font-bold text-blue-800 text-base mb-2\">Painting</h3>\n          <p class=\"text-gray-500 text-xs leading-relaxed\">Interior &amp; exterior painting, color consultation, pressure washing, deck staining.</p>\n        </div>\n        <div class=\"card-hover bg-blue-50 rounded-2xl p-6 border border-blue-100\">\n          <div class=\"text-3xl mb-3\">🧱</div>\n          <h3 class=\"font-bold text-blue-800 text-base mb-2\">Drywall</h3>\n          <p class=\"text-gray-500 text-xs leading-relaxed\">Patches, water damage repair, full installations, taping, mudding, and texturing.</p>\n        </div>\n        <div class=\"card-hover bg-blue-50 rounded-2xl p-6 border border-blue-100\">\n          <div class=\"text-3xl mb-3\">🏠</div>\n          <h3 class=\"font-bold text-blue-800 text-base mb-2\">Tile Work</h3>\n          <p class=\"text-gray-500 text-xs leading-relaxed\">Floor tile, backsplashes, bathroom tile, re-grouting, and custom tile installations.</p>\n        </div>\n        <div class=\"card-hover bg-blue-50 rounded-2xl p-6 border border-blue-100\">\n          <div class=\"text-3xl mb-3\">🔨</div>\n          <h3 class=\"font-bold text-blue-800 text-base mb-2\">General Repairs</h3>\n          <p class=\"text-gray-500 text-xs leading-relaxed\">Anything on your to-do list — furniture assembly, gutter cleaning, caulking, weatherproofing.</p>\n        </div>\n        <div class=\"card-hover bg-orange-50 rounded-2xl p-6 border border-orange-200\">\n          <div class=\"text-3xl mb-3\">🚨</div>\n          <h3 class=\"font-bold text-orange-700 text-base mb-2\">Emergency Service</h3>\n          <p class=\"text-gray-500 text-xs leading-relaxed\">Burst pipes, power outages, structural damage — we respond fast, 24 hours a day, 7 days a week.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Service Area -->\n  <section id=\"area\" class=\"py-14 bg-gray-800 text-white text-center\">\n    <div class=\"max-w-4xl mx-auto px-6\">\n      <h3 class=\"text-2xl font-bold mb-3\">Service Area</h3>\n      <p class=\"text-gray-300 text-lg\">Serving all of South County: <strong class=\"text-white\">Wakefield · Narragansett · South Kingstown · Westerly · Charlestown · North Kingstown · Richmond · Exeter</strong></p>\n    </div>\n  </section>\n\n  <!-- Reviews -->\n  <section id=\"reviews\" class=\"py-20 bg-gray-50\">\n    <div class=\"max-w-5xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-bold text-blue-800 text-center mb-12\">What South County Says</h2>\n      <div class=\"grid md:grid-cols-3 gap-6\">\n        <div class=\"bg-white rounded-2xl p-6 shadow-sm border border-gray-100\">\n          <div class=\"text-yellow-400 text-lg mb-3\">★★★★★</div>\n          <p class=\"text-gray-600 text-sm italic mb-4\">\"Had a pipe burst at 11pm on a Sunday. FixIt Pro picked up on the first ring and had a plumber at my Narragansett home within 45 minutes. Fixed it cleanly and charged a very fair rate. Lifesavers.\"</p>\n          <div class=\"flex items-center gap-3\">\n            <div class=\"w-9 h-9 bg-blue-700 text-white rounded-full flex items-center justify-center text-xs font-bold\">DH</div>\n            <div>\n              <div class=\"font-semibold text-gray-800 text-sm\">Dave H., Narragansett</div>\n              <div class=\"text-gray-400 text-xs\">Google Review</div>\n            </div>\n          </div>\n        </div>\n        <div class=\"bg-white rounded-2xl p-6 shadow-sm border border-gray-100\">\n          <div class=\"text-yellow-400 text-lg mb-3\">★★★★★</div>\n          <p class=\"text-gray-600 text-sm italic mb-4\">\"Updated our entire bathroom in South Kingstown — tile, vanity, lighting, everything. The craftsmanship was impeccable and they finished two days early. Our bathroom looks like a hotel suite now.\"</p>\n          <div class=\"flex items-center gap-3\">\n            <div class=\"w-9 h-9 bg-orange-600 text-white rounded-full flex items-center justify-center text-xs font-bold\">SP</div>\n            <div>\n              <div class=\"font-semibold text-gray-800 text-sm\">Sue P., South Kingstown</div>\n              <div class=\"text-gray-400 text-xs\">Google Review</div>\n            </div>\n          </div>\n        </div>\n        <div class=\"bg-white rounded-2xl p-6 shadow-sm border border-gray-100\">\n          <div class=\"text-yellow-400 text-lg mb-3\">★★★★★</div>\n          <p class=\"text-gray-600 text-sm italic mb-4\">\"My go-to for everything around the house. They've done electrical, painting, and a new deck for our Westerly cottage. Always professional, always on time. I recommend them to every neighbor.\"</p>\n          <div class=\"flex items-center gap-3\">\n            <div class=\"w-9 h-9 bg-blue-700 text-white rounded-full flex items-center justify-center text-xs font-bold\">MR</div>\n            <div>\n              <div class=\"font-semibold text-gray-800 text-sm\">Mike R., Westerly</div>\n              <div class=\"text-gray-400 text-xs\">Google Review</div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Request Quote Form -->\n  <section id=\"contact\" class=\"py-20 bg-white\">\n    <div class=\"max-w-2xl mx-auto px-6\">\n      <h2 class=\"text-4xl font-bold text-blue-800 text-center mb-3\">Request a Quote</h2>\n      <p class=\"text-center text-gray-500 mb-8\">Fill out the form below and we'll get back to you within 2 hours. For emergencies, call directly.</p>\n      <form class=\"bg-gray-50 rounded-2xl p-8 shadow-md space-y-5\">\n        <div class=\"grid md:grid-cols-2 gap-5\">\n          <div>\n            <label class=\"block text-sm font-medium text-gray-700 mb-1\">Name</label>\n            <input type=\"text\" placeholder=\"Your full name\" class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-600\" />\n          </div>\n          <div>\n            <label class=\"block text-sm font-medium text-gray-700 mb-1\">Phone</label>\n            <input type=\"tel\" placeholder=\"(401) 555-0000\" class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-600\" />\n          </div>\n        </div>\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700 mb-1\">Email</label>\n          <input type=\"email\" placeholder=\"you@email.com\" class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-600\" />\n        </div>\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700 mb-1\">Service Type</label>\n          <select class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-600\">\n            <option>Plumbing</option>\n            <option>Electrical</option>\n            <option>Carpentry</option>\n            <option>Painting</option>\n            <option>Drywall</option>\n            <option>Tile Work</option>\n            <option>General Repairs</option>\n            <option>Multiple Services</option>\n          </select>\n        </div>\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700 mb-1\">Describe the Job</label>\n          <textarea rows=\"3\" placeholder=\"Tell us what needs to be done...\" class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-600\"></textarea>\n        </div>\n        <div>\n          <label class=\"block text-sm font-medium text-gray-700 mb-1\">Urgency Level</label>\n          <select class=\"w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-600\">\n            <option>Regular — Schedule within 1–2 weeks</option>\n            <option>Within 48 Hours</option>\n            <option>Emergency — Need help now</option>\n          </select>\n        </div>\n        <button type=\"submit\" class=\"w-full bg-blue-700 hover:bg-blue-800 text-white py-3 rounded-lg font-bold transition-colors\">Submit Request</button>\n      </form>\n    </div>\n  </section>\n\n  <!-- Footer -->\n  <footer class=\"bg-blue-900 text-blue-200 py-10 text-center\">\n    <div class=\"max-w-7xl mx-auto px-6\">\n      <div class=\"text-white font-bold text-2xl mb-2\">🚨 Emergency? Call <a href=\"tel:4015550911\" class=\"text-orange-400 hover:underline\">(401) 555-0911</a></div>\n      <div class=\"text-white font-bold text-lg mb-2 mt-4\">FixIt Pro</div>\n      <p class=\"text-sm\">Licensed &amp; Insured · RI Contractor Lic. #RC-04821 · Serving South County Since 2005</p>\n      <p class=\"text-xs text-blue-400 mt-4\">&copy; 2026 FixIt Pro. All rights reserved.</p>\n    </div>\n  </footer>\n\n</body>\n</html>\n",
