# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production
PORT=8080                     # HTTP listen port
JWT_SECRET=change-me-in-production          # Secret for signing JWTs (use a long random string)
MASTER_API_KEY=n3ware_master_key_change_me  # Master API key for X-API-Key header

# ── Storage backend ───────────────────────────────────────────────────────────
STORAGE_BACKEND=local         # local (JSON files) | firestore
DATA_DIR=./data/sites         # Root directory for local storage

# ── Stripe billing ────────────────────────────────────────────────────────────
# Leave blank to run in mock mode (returns fake billing data)
STRIPE_SECRET_KEY=            # sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=        # whsec_... (from Stripe dashboard)
STRIPE_STARTER_PRICE_ID=      # price_... for Starter plan
STRIPE_PRO_PRICE_ID=          # price_... for Pro plan
STRIPE_AGENCY_PRICE_ID=       # price_... for Agency plan

# ── Transactional email ───────────────────────────────────────────────────────
# Leave both blank to run in mock mode (logs emails to console + data/emails.json)
EMAIL_PROVIDER=               # sendgrid | postmark
SENDGRID_API_KEY=             # SG.xxx
POSTMARK_API_KEY=             # xxx-xxx-xxx
EMAIL_FROM=hello@n3ware.com   # From address

# ── Cloudflare (domains + CDN) ────────────────────────────────────────────────
# Leave blank to run domains in mock mode
CLOUDFLARE_API_TOKEN=         # Cloudflare API token
CLOUDFLARE_ACCOUNT_ID=        # Cloudflare account ID
CLOUDFLARE_ZONE_ID=           # Zone ID for CDN purge (existing zone)
CF_ZONE_ID=                   # Alias used by CDN purge helper
CF_API_TOKEN=                 # Alias used by CDN purge helper

# ── Cloud file storage ────────────────────────────────────────────────────────
# Leave blank to store files locally in data/uploads/
STORAGE_PROVIDER=             # r2 | gcs
# Cloudflare R2 (S3-compatible)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=                  # https://xxx.r2.cloudflarestorage.com
# Google Cloud Storage
GCS_BUCKET=

# ── Google Cloud (Firestore + Cloud Run) ──────────────────────────────────────
GOOGLE_CLOUD_PROJECT=         # GCP project ID
GCP_PROJECT_ID=               # Same as GOOGLE_CLOUD_PROJECT
GCP_BACKEND_NAME=             # Cloud CDN URL map name (for cache invalidation)

# ── CDN invalidation ──────────────────────────────────────────────────────────
CDN_PROVIDER=none             # none | cloudflare | gcp

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_MAX_SIZE=500            # LRU cache max entries
CACHE_TTL_MS=300000           # Cache TTL in ms (5 minutes)

# ── Site serving ──────────────────────────────────────────────────────────────
N3WARE_SCRIPT_URL=/n3ware.js  # URL to the n3ware.js script (override for CDN)

# ── AI Migration (Anthropic Claude) ──────────────────────────────────────────
# Leave blank to run in mock mode (cheerio-based HTML cleanup)
ANTHROPIC_API_KEY=             # sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6   # Override Claude model (optional)
